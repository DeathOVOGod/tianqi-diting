// 每个角色的"原位"坐标
function getHomePos(dept) {
    var el = document.getElementById('off-' + dept);
    if (!el) return {x: 0, y: 0};
    return {x: getActualLeft(el), y: parseFloat(el.style.top || 0)};
}

// 计算两人中间位置
function getMidPos(dept1, dept2, ratio) {
    ratio = ratio || 0.8;
    var p1 = getHomePos(dept1);
    var p2 = getHomePos(dept2);
    // 居中为canvas宽度/2，需要根据元素宽度调整
    var w1 = 40, w2 = 40;
    var c1 = p1.x + w1/2, c2 = p2.x + w2/2;
    var midC = c1 + (c2 - c1) * ratio;
    var midY = p1.y + (p2.y - p1.y) * ratio;
    return {x: midC - w1/2, y: midY};
}

// 获取上级位置（用于移动到上级面前的坐标）
function getInFrontOfPos(subDept, bossDept) {
    var subHome = getHomePos(subDept);
    var bossHome = getHomePos(bossDept);
    // 下属移动到上级面前（上级和下属之间，偏向上级）
    return getMidPos(subDept, bossDept, 0.3);
}

