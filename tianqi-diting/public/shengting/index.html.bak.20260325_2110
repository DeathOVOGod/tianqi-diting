            this._runSixMinistry(dept, command);
            return;
        }

        // ========== 情况2：有上级部门（内阁/内廷下属） ==========
        if (parent) {
            this._runWithParent(dept, command, parent);
            return;
        }

        // ========== 情况3：直接部门（皇帝->冥王->直接下属 或 直接->皇帝）==========
