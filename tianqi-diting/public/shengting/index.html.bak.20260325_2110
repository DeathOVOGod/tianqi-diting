function openTaskDialog(dept){
  document.getElementById('d-dept-name').textContent='📋 部门：'+MDEPT[dept];
  document.getElementById('d-command').value='';
  var presets=document.getElementById('d-presets');
  presets.innerHTML='';
  var acts=MACT[dept]||[];
  acts.forEach(function(a){var btn=document.createElement('button');btn.className='preset-btn';btn.textContent=a;btn.onclick=function(){document.getElementById('d-command').value=a;};presets.appendChild(btn);});

  // 状态选择器
  var statusPresets=document.getElementById('d-status-presets');
  statusPresets.innerHTML='';
  var stMap=STATUS_MAP;
  // 可选状态（排除idle/completed/error）
  var selectable=['executing','thinking','drafting','investigating','marching','resting','worshipping','drilling','on-duty','happy','thinking-hard','angry','tired'];
  var selSt='executing';
  selectable.forEach(function(s){
    var info=stMap[s];
    var btn=document.createElement('button');
    btn.className='preset-btn status-btn';
    btn.textContent=info.icon+' '+info.name;
    btn.dataset.status=s;
    btn.style.borderColor=info.color;
    if(s===selSt)btn.style.background='rgba(255,215,0,0.2)';
    btn.onclick=function(){
      document.querySelectorAll('.status-btn').forEach(function(b){b.style.background='rgba(255,215,0,0.08)';});
      btn.style.background='rgba(255,215,0,0.2)';
      selSt=s;
    };
    statusPresets.appendChild(btn);
  });
  dialogEl.dataset.selectedStatus='executing';

  dialogEl.classList.add('show');overlayEl.classList.add('show');
  dialogEl.dataset.dept=dept;
  document.getElementById('d-command').focus();
}

function closeDialog(){
  dialogEl.classList.remove('show');overlayEl.classList.remove('show');
}

document.getElementById('d-cancel').onclick=closeDialog;
overlayEl.onclick=closeDialog;

document.getElementById('d-confirm').onclick=function(){
  var dept=dialogEl.dataset.dept;
  var cmd=document.getElementById('d-command').value.trim();
  if(!cmd)return;
  var selSt=dialogEl.dataset.selectedStatus||'executing';
  closeDialog();
  fetch('/api/task',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({department:dept,command:cmd,status:selSt})}).then(function(r){return r.json();}).then(function(data){
    var info=STATUS_MAP[selSt]||{icon:'⚡',name:'执行中'};
    setOfficialState(dept,selSt);
    updBanner(dept,cmd,info.icon+' '+info.name+'...');
  }).catch(function(e){console.error(e);});
};

function setOfficialState(dept,state,result){
  var el=document.getElementById('off-'+dept);
  if(!el)return;
  // 移除所有16种状态类
  var allStates=['idle','executing','completed','error','thinking','drafting','investigating','marching','resting','worshipping','drilling','on-duty','happy','thinking-hard','angry','tired'];
  allStates.forEach(function(s){el.classList.remove(s);});
  el.classList.add(state);

  // 更新头顶气泡内容与颜色
  var info=STATUS_MAP[state]||{icon:'⬜',color:'#555555',name:'空闲'};
  var bubble=el.querySelector('.bubble');
  var stateEl=document.getElementById('state-'+dept);
  if(stateEl){
    stateEl.textContent=info.icon+' '+info.name;
    stateEl.style.color=info.color;
  }
  if(bubble){
    bubble.style.borderColor=info.color;
    bubble.style.setProperty('--bubble-color',info.color);
  }

  // 移除旧飘字
  var old=el.querySelector('.result-bubble');
  if(old)old.remove();
  if(state==='completed'&&result){
    var rBubble=document.createElement('div');
    rBubble.className='result-bubble';
    rBubble.textContent=result;
    el.appendChild(rBubble);
    setTimeout(function(){rBubble.remove();el.classList.remove('completed');el.classList.add('idle');},2800);
  }
}

function updBanner(dept,action,status){
  taskBannerEl.classList.add('show');
  document.getElementById('tb-dept').textContent=MDEPT[dept]||dept;
  document.getElementById('tb-action').textContent=action;
  document.getElementById('tb-status').textContent=status;
}

function pollTask(){
  fetch('/api/task').then(function(r){return r.json();}).then(function(data){
    if(data.status==='idle'){
      taskBannerEl.classList.remove('show');
      // 恢复所有idle
      var allSt=['idle','executing','completed','error','thinking','drafting','investigating','marching','resting','worshipping','drilling','on-duty','happy','thinking-hard','angry','tired'];
      MIDS.forEach(function(d){var el=document.getElementById('off-'+d);if(el){allSt.forEach(function(s){el.classList.remove(s);});if(!el.classList.contains('idle'))el.classList.add('idle');}});
      return;
    }
    if(data.department){
      var st=data.status;
      var info=STATUS_MAP[st]||{icon:'⚡',color:'#ffd700',name:st};
      // 自动完成的状态：executing/marching/dilling/worshipping 完成后显示completed
      if(st==='completed'){
        setOfficialState(data.department,'completed',data.result||'完成');
        updBanner(data.department,data.action||'',info.icon+' 已完成');
        // 3.5秒后恢复idle
        setTimeout(function(){
          fetch('/api/task').then(function(r){return r.json();}).then(function(d2){
            if(d2.status==='completed'||d2.status==='idle'){
              setOfficialState(d2.department,'idle');
              taskBannerEl.classList.remove('show');
            }
          }).catch(function(){});
        },3500);
      } else if(st==='error'){
        setOfficialState(data.department,'error');
        updBanner(data.department,data.action||'','✗ 失败');
      } else {
        // 持久状态：thinking/drafting/investigating/resting/on-duty/happy/thinking-hard/angry/tired/marching/dilling/worshipping
        setOfficialState(data.department,st);
        updBanner(data.department,data.action||data.command||'',info.icon+' '+info.name);
      }
    }
  }).catch(function(e){console.error(e);});
}

