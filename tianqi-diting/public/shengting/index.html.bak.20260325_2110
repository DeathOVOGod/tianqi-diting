        setOfficialState(dept, 'receiving');
        logChain(dept, '📜 ' + MDEPT[dept] + ' → 冥王领旨');
        var target1 = getMidPos(dept, mw, 0.3);
        document.getElementById('off-' + dept).animateTo(target1.x, target1.y, function() {
            // Step 2: 部门回位执行
            setOfficialState(dept, 'moving');
            logChain(dept, '⚡ ' + MDEPT[dept] + ' 执行中：' + command);
            updBanner(dept, command, '⚡ 执行中...');
            document.getElementById('off-' + dept).animateTo(deptHome.x, deptHome.y, function() {
                setOfficialState(dept, 'executing');
                self.cbTimer = setTimeout(function() {
                    // Step 3: 执行完成，显示汇报
                    setOfficialState(dept, 'completed', '✓ 汇报');
                    logChain(dept, '✅ ' + MDEPT[dept] + ' ✓ 任务完成！', true);
                    updBanner(dept, command, '✅ 已完成，向上级汇报...');
                    // Step 4: 部门向冥王汇报
                    setOfficialState(dept, 'reporting');
                    var target2 = getMidPos(dept, mw, 0.3);
                    setOfficialState(dept, 'moving');
                    document.getElementById('off-' + dept).animateTo(target2.x, target2.y, function() {
                        setOfficialState(dept, 'reporting');
                        setOfficialState(mw, 'receiving');
                        logChain(mw, '📜 冥王帝尘 接收汇报', true);
                        // Step 5: 部门回位，冥王回位
                        setOfficialState(dept, 'moving');
                        document.getElementById('off-' + dept).animateTo(deptHome.x, deptHome.y, function() {
                            setOfficialState(dept, 'idle');
                            setOfficialState(mw, 'moving');
                            document.getElementById('off-' + mw).animateTo(mwHome.x, mwHome.y, function() {
                                setOfficialState(mw, 'idle');
                                self.running = false;
                                updBanner(dept, command, '✅ 调度完成');
                                self.cbTimer = setTimeout(function() {
                                    taskBannerEl.classList.remove('show');
                                }, 3000);
                            }, {label:'回位', labelColor:'#ffd700'});
                        }, {label:'回位', labelColor:'#88ccff'});
                    });
                }, 1800);
            }, {label:'回位执行', labelColor:'#88ccff'});
        }, {run:true, label:'领旨', labelColor:'#ffd700'});
    }
};

// ====== 修改 openTaskDialog 和 confirm 逻辑 ======
var dialogEl = document.getElementById('task-dialog');
var overlayEl = document.getElementById('dialog-overlay');

function openTaskDialog(dept) {
    document.getElementById('d-dept-name').textContent = '📋 部门：' + MDEPT[dept];
    document.getElementById('d-command').value = '';
    var presets = document.getElementById('d-presets');
    presets.innerHTML = '';
    var acts = MACT[dept] || [];
    acts.forEach(function(a) {
        var btn = document.createElement('button');
        btn.className = 'preset-btn';
        btn.textContent = a;
        btn.onclick = function() { document.getElementById('d-command').value = a; };
        presets.appendChild(btn);
    });
    var statusPresets = document.getElementById('d-status-presets');
    statusPresets.innerHTML = '';
    var selectable = ['executing','thinking','drafting','investigating','marching','resting','worshipping','drilling','on-duty','happy','thinking-hard','angry','tired'];
    selectable.forEach(function(s) {
        var info = STATUS_MAP[s];
        var btn = document.createElement('button');
        btn.className = 'preset-btn status-btn';
        btn.textContent = info.icon + ' ' + info.name;
        btn.dataset.status = s;
        btn.style.borderColor = info.color;
        if (s === 'executing') btn.style.background = 'rgba(255,215,0,0.2)';
        btn.onclick = function() {
            document.querySelectorAll('.status-btn').forEach(function(b) { b.style.background = 'rgba(255,215,0,0.08)'; });
            btn.style.background = 'rgba(255,215,0,0.2)';
            dialogEl.dataset.selectedStatus = s;
        };
        statusPresets.appendChild(btn);
    });
    dialogEl.dataset.selectedStatus = 'executing';
    dialogEl.classList.add('show');
    overlayEl.classList.add('show');
    dialogEl.dataset.dept = dept;
    document.getElementById('d-command').focus();
}

function closeDialog() {
    dialogEl.classList.remove('show');
    overlayEl.classList.remove('show');
}
document.getElementById('d-cancel').onclick = closeDialog;
overlayEl.onclick = closeDialog;

document.getElementById('d-confirm').onclick = function() {
    var dept = dialogEl.dataset.dept;
    var cmd = document.getElementById('d-command').value.trim();
    if (!cmd) return;
    closeDialog();
    // 启动任务调度动画
    fsm.start(dept, cmd);
    // 同时发送API请求
    fetch('/api/task', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ department: dept, command: cmd, status: 'executing' })
    }).catch(function(e) { console.error(e); });
};

// 修改官方点击事件处理
MIDS.forEach(function(dept) {
    var el = document.getElementById('off-' + dept);
    if (!el) return;
    el.onclick = function(e) {
        e.stopPropagation();
        if (fsm.running) {
            // 已经在运行，显示提示
            updBanner(dept, '...', '⏳ 任务执行中，请稍候');
            return;
        }
        openTaskDialog(dept);
    };
});

