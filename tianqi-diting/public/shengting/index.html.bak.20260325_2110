function drawBackground(){ctx.clearRect(0,0,W,H);var sk=ctx.createLinearGradient(0,0,0,H);sk.addColorStop(0,"#04040e");sk.addColorStop(0.5,"#080616");sk.addColorStop(1,"#0e0818");ctx.fillStyle=sk;ctx.fillRect(0,0,W,H);ctx.fillStyle="#1a0e0a";ctx.fillRect(0,15,W,28);for(var x=50;x<W;x+=70){ctx.fillStyle="#241208";ctx.fillRect(x,15,36,28);}var fl=ctx.createLinearGradient(0,H*0.58,0,H);fl.addColorStop(0,"#140e1c");fl.addColorStop(1,"#080610");ctx.fillStyle=fl;ctx.fillRect(0,H*0.58,W,H*0.42);ctx.fillStyle="#1e1630";ctx.fillRect(W*0.38,H*0.58,W*0.24,H*0.42);}
