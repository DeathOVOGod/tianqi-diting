  <!-- 翰林院 -->
  <div class="official" id="off-hanlin" style="min-width:48px;left:380px;top:430px"><div class="bubble"><div class="bubble-name">📚 翰林院</div><div class="bubble-state" id="state-hanlin">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">翰林院大学士</div><div class="t-title">典章制度</div><div class="t-dept">📚 翰林院</div></div></div>

  <!-- 内廷掌印 -->
  <div class="official" id="off-neiting" style="min-width:48px;right:230px;top:230px"><div class="bubble"><div class="bubble-name">⚫ 内廷掌印</div><div class="bubble-state" id="state-neiting">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">内廷掌印</div><div class="t-title">内廷总负责人</div><div class="t-dept">⚫ 内廷</div></div></div>

  <!-- 锦衣卫 -->
  <div class="official" id="off-jinwei" style="min-width:48px;right:380px;top:430px"><div class="bubble"><div class="bubble-name">🛠 锦衣卫</div><div class="bubble-state" id="state-jinwei">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">锦衣卫指挥</div><div class="t-title">缉事记律</div><div class="t-dept">🛠 锦衣卫</div></div></div>

  <!-- 通政司 -->
  <div class="official" id="off-tongzheng" style="min-width:48px;right:230px;top:430px"><div class="bubble"><div class="bubble-name">📋 通政司</div><div class="bubble-state" id="state-tongzheng">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">通政司</div><div class="t-title">章奏部经</div><div class="t-dept">📋 通政司</div></div></div>

  <!-- 钦天监 -->
