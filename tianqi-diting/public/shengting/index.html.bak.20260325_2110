  <!-- 内阁首辅 -->
  <div class="official" id="off-neige" style="min-width:48px;left:230px;top:230px"><div class="bubble"><div class="bubble-name">⏳ 内阁首辅</div><div class="bubble-state" id="state-neige">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">内阁首辅</div><div class="t-title">内阁总负责人</div><div class="t-dept">🏛 内阁</div></div></div>

  <!-- 议政院 -->
  <div class="official" id="off-yizheng" style="min-width:48px;left:80px;top:430px"><div class="bubble"><div class="bubble-name">🏛 议政院</div><div class="bubble-state" id="state-yizheng">⬜ 空闲</div><div class="bubble-arrow"></div></div><canvas class="char-canvas" width="40" height="56"></canvas><div class="tooltip-card"><div class="t-name">议政院大学士</div><div class="t-title">议政辅弼</div><div class="t-dept">🏛 议政院</div></div></div>

