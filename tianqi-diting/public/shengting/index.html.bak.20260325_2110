function updSS(){fetch("/api/status").then(function(r){return r.json();}).then(function(data){document.getElementById("s-cpu").textContent=data.loadavg?data.loadavg[0].toFixed(2):"—";document.getElementById("b-cpu").style.width=Math.min(100,data.loadavg?data.loadavg[0]*20:0)+"%";document.getElementById("s-mem").textContent=data.memory?data.memory.percent+"%":"—";document.getElementById("b-mem").style.width=data.memory?data.memory.percent+"%":"0%";document.getElementById("s-disk").textContent=data.disk?data.disk.percent+"%":"—";document.getElementById("b-disk").style.width=data.disk?Math.min(100,data.disk.percent)+"%":"0%";document.getElementById("s-uptime").textContent=data.uptime?fmtU(data.uptime):"—";}).catch(function(){});}
function updCm(){fetch("/api/commands").then(function(r){return r.json();}).then(function(data){var list=document.getElementById("cmd-list");if(!data.commands||data.commands.length===0)return;list.innerHTML=data.commands.slice(0,8).map(function(c){var t=new Date(c.ts);var time=t.getHours()+":"+t.getMinutes().toString().padStart(2,"0");var cls=c.status==="sent"?"sent":c.status==="failed"?"failed":"";var text=c.command.length>30?c.command.substring(0,30)+"...":c.command;return'<div class="cmd-item '+cls+'"><div class="cmd-dot"></div><div class="cmd-time">'+time+'</div><div class="cmd-text">'+text+'</div></div>';}).join("");}).catch(function(){});}
function loop(ts){aT=ts/1000;drawBackground();drawDragonThrone();drawLanterns();drawCharacters();requestAnimationFrame(loop);}
requestAnimationFrame(loop);updCk();updSS();updCm();setInterval(updSS,15000);setInterval(updCm,8000);

// ====== 任务联动系统 ======
var MDEPT={emperor:'神帝陛下',mingwang:'冥王帝尘',neige:'内阁首辅',yizheng:'议政院',ducha:'都察院',hanlin:'翰林院',neiting:'内廷掌印',jinwei:'锦衣卫',tongzheng:'通政司',qintian:'钦天监',liubushangling:'六部尚书令',libu:'吏部',hubu:'户部',libub:'礼部',bingbu:'兵部',xingbu:'刑部',gongbu:'工部'};
var MACT={emperor:['颁布大政','颁发圣旨','召见群臣'],mingwang:['调度任务','冥指示下','幽冥令'],neige:['拟旨','召开内阁会议','调度政务'],yizheng:['议政','召开议事','建言献策'],ducha:['监察百官','弹劾','巡察'],hanlin:['起草文书','修订典章','编纂'],neiting:['掌印','批红','下发诏书'],jinwei:['缉查','巡查','拿办'],tongzheng:['传达章奏','上报下达','收发奏章'],qintian:['观星','测运','预言'],liubushangling:['调配六部','统筹政务','发布政令'],libu:['人事调度','考核官员','任免'],hubu:['查看资源','清点钱粮','户籍'],libub:['发帖','礼仪外交','祭祀'],bingbu:['整军','军政','武备'],xingbu:['审案','判决','执法'],gongbu:['营建','工程','营造']};

// 状态映射表（16种状态）
var STATUS_MAP={
  idle:{icon:'⬜',color:'#555555',name:'空闲'},
  executing:{icon:'⚡',color:'#ffd700',name:'执行中'},
  completed:{icon:'✅',color:'#44cc44',name:'已完成'},
  error:{icon:'❌',color:'#ff4444',name:'错误'},
  thinking:{icon:'⏳',color:'#888888',name:'思考中'},
