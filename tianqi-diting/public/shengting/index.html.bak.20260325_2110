function drawLanterns(){var ps=[[160,80],[500,70],[W/2,60],[780,70],[1120,80]];ps.forEach(function(p,i){var col=i%2===0?"#cc4400":"#aa3300";ctx.strokeStyle="rgba(100,80,20,0.6)";ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(p[0],0);ctx.lineTo(p[0],p[1]-10);ctx.stroke();var fl=1+0.08*Math.sin(aT*3+i)+0.04*Math.sin(aT*7+i*2);ctx.fillStyle=col;ctx.globalAlpha=0.3*fl;ctx.beginPath();ctx.ellipse(p[0],p[1],12,8,0,0,Math.PI*2);ctx.fill();ctx.globalAlpha=1;ctx.fillStyle=col;ctx.fillRect(p[0]-8,p[1]-8,16,14);ctx.fillStyle="rgba(255,200,100,0.8)";ctx.fillRect(p[0]-6,p[1]-6,12,10);ctx.fillStyle="rgba(255,150,50,"+(0.15*fl)+")";ctx.beginPath();ctx.ellipse(p[0],p[1],20,15,0,0,Math.PI*2);ctx.fill();});}
function drawCharacters(){MIDS.forEach(function(d,i){var el=document.getElementById("off-"+d);if(!el)return;var cc=el.querySelector(".char-canvas");if(!cc)return;var cctx=cc.getContext("2d");var col=MC[d];var bob=Math.sin(aT*2+i)*1.5;cctx.clearRect(0,0,cc.width,cc.height);cctx.fillStyle=col;cctx.fillRect(8,4+bob,24,10);cctx.fillRect(6,8+bob,28,4);cctx.fillStyle="#FFCC99";cctx.fillRect(10,12+bob,20,14);cctx.fillStyle="#000";cctx.fillRect(13,16+bob,3,3);cctx.fillRect(20,16+bob,3,3);cctx.fillStyle=col;cctx.fillRect(8,26+bob,24,20);cctx.fillRect(0,28+bob,8,12);cctx.fillRect(32,28+bob,8,12);cctx.fillStyle="#444444";cctx.fillRect(10,46+bob,20,8);cctx.fillStyle="#FFD700";cctx.font="bold 8px monospace";cctx.textAlign="center";cctx.fillText(MCH[d],20,60+bob);});}
function fmtU(s){var h=Math.floor(s/3600);return h+"h "+Math.floor((s%3600)/60)+"m";}
