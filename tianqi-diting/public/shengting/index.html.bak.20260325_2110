var trails = [];
function addTrail(x, y, color) {
    trails.push({x: x, y: y, color: color, r: 8, alpha: 0.7, t: Date.now()});
}
function drawTrails() {
    var tCtx = document.getElementById('trail-canvas').getContext('2d');
    tCtx.clearRect(0, 0, 1280, 800);
    var now = Date.now();
    trails = trails.filter(function(t) { return now - t.t < 700; });
    trails.forEach(function(t) {
        var age = (now - t.t) / 700;
        var alpha = t.alpha * (1 - age);
        var r = t.r * (1 - age * 0.5);
        var g = tCtx.createRadialGradient(t.x, t.y, 0, t.x, t.y, r);
        var hex = t.color;
        // hex like #ffd700 -> rgba(255,215,0,alpha)
        var r1 = parseInt(hex.substr(1,2), 16);
        var g1 = parseInt(hex.substr(3,2), 16);
        var b1 = parseInt(hex.substr(5,2), 16);
        g.addColorStop(0, 'rgba('+r1+','+g1+','+b1+','+alpha.toFixed(2)+')');
        g.addColorStop(1, 'rgba(0,0,0,0)');
        tCtx.fillStyle = g;
        tCtx.beginPath();
        tCtx.arc(t.x, t.y, r, 0, Math.PI * 2);
        tCtx.fill();
    });
}

// ====== Official animateTo 方法 ======
var MC_COLORS = {emperor:"#ffd700",mingwang:"#888888",neige:"#ffaa33",yizheng:"#ffaa33",ducha:"#aa66ff",hanlin:"#44aaff",neiting:"#ff4444",jinwei:"#ff4444",tongzheng:"#66ccff",qintian:"#cc66ff",liubushangling:"#9933ff",libu:"#ffaa66",hubu:"#66ff88",libub:"#aa66ff",bingbu:"#ff6666",xingbu:"#ff88aa",gongbu:"#aaff66"};

// 将 right 定位转换为实际 left
function getActualLeft(el) {
    var right = el.style.right;
    if (right) {
        return 1280 - parseFloat(right) - 40;
    }
    var left = el.style.left;
    if (left && left.endsWith('%')) {
        return (parseFloat(left) / 100 * 1280) - 20;
    }
    if (left && left.includes('calc')) {
        // Extract percentage from calc(XX%)
        var pct = left.match(/calc\(([\d.]+)%\)/);
        if (pct) return (parseFloat(pct[1]) / 100 * 1280) - 20;
    }
    return parseFloat(left || 0);
}

MIDS.forEach(function(dept) {
    var el = document.getElementById('off-' + dept);
    if (!el) return;

    el.animateTo = function(targetX, targetY, callback, opts) {
        opts = opts || {};
        var speed = opts.run ? 4.5 : 2.5;
        var labelText = opts.label || '';
        var labelColor = opts.labelColor || '#ffd700';
        var self = this;
        var startX = getActualLeft(el);
        var startY = parseFloat(el.style.top || 0);
        var dx = targetX - startX;
        var dy = targetY - startY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        var vx = dx / dist * speed;
        var vy = dy / dist * speed;
        var step = 0;
        var maxSteps = Math.ceil(dist / speed) + 100;
        var trailColor = MC_COLORS[dept] || '#ffd700';
        var lastTrailTime = 0;

        // Show label
        if (labelText) {
            var lbl = el.querySelector('.status-label');
            if (lbl) {
                lbl.textContent = labelText;
                lbl.style.setProperty('--lc', labelColor);
                lbl.style.color = labelColor;
            }
            el.classList.add('show-status-label');
        }
        el.classList.add('moving');

        function frame() {
            step++;
            var curX = getActualLeft(el);
            var curY = parseFloat(el.style.top || 0);
            var ndx = targetX - curX;
            var ndy = targetY - curY;
            var ndist = Math.sqrt(ndx * ndx + ndy * ndy);
            var nx, ny;
            if (ndist <= speed) {
                nx = targetX; ny = targetY;
            } else {
                nx = curX + ndx / ndist * speed;
                ny = curY + ndy / ndist * speed;
            }
            // Apply position (always use left)
            el.style.right = '';
            el.style.left = nx + 'px';
            el.style.top = ny + 'px';

            // Add trail
            var now = Date.now();
            if (now - lastTrailTime > 70) {
                var ctr = getOfficialCenter(dept);
                if (ctr) addTrail(ctr.x, ctr.y, trailColor);
                lastTrailTime = now;
            }

            if (ndist <= speed || step > maxSteps) {
                el.style.left = targetX + 'px';
                el.style.top = targetY + 'px';
                el.classList.remove('moving');
                if (labelText) {
                    setTimeout(function() {
                        el.classList.remove('show-status-label');
                    }, 800);
                }
                setTimeout(function() {
                    if (callback) callback();
                }, 200);
                return;
            }
            // Fallback: force complete after 5 seconds
            setTimeout(function() {
                el.style.left = targetX + 'px';
                el.style.top = targetY + 'px';
                el.classList.remove('moving');
                el.classList.remove('show-status-label');
                if (callback) callback();
            }, 5000);
            requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
    };
});

function getOfficialCenter(dept) {
    var el = document.getElementById('off-' + dept);
    if (!el) return null;
    var stage = document.getElementById('stage');
    var sr = stage.getBoundingClientRect();
    var er = el.getBoundingClientRect();
    return {
        x: er.left - sr.left + er.width / 2,
        y: er.top - sr.top + er.height / 2
    };
}

